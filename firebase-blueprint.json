    {
      "collectionId": "tickets",
      "fields": [
        {
          "name": "userId",
          "type": "string"
        },
        {
          "name": "userNick",
          "type": "string"
        },
        {
          "name": "category",
          "type": "string"
        },
        {
          "name": "status",
          "type": "string"
        },
        {
          "name": "messages",
          "type": "array"
        },
        {
          "name": "createdAt",
          "type": "string"
        },
        {
          "name": "updatedAt",
          "type": "string"
        }
