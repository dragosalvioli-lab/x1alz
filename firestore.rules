rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /payments/{paymentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /logs/{logId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
